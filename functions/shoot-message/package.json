{
    "name": "shoot-message",
    "description": "A lambda function that sends a message to the configured recipient through MailJet.",
    "version": "1.0.0",
    "license": "MIT",
    "type": "module",
    "engines": {
        "node": ">=20.19.0 <21"
    },
    "scripts": {
        "deploy": "npm run build-template && npm run serverless-deploy",
        "serverless-deploy": "serverless deploy --stage prod",
        "build-template": "mjml templates/input.mjml -o templates/html.hbs",
        "lint": "eslint ."
    },
    "dependencies": {
        "cors": "2.8.6",
        "express": "4.22.2",
        "handlebars": "4.7.9",
        "node-mailjet": "6.0.11",
        "serverless-http": "3.2.0",
        "yup": "1.7.1"
    },
    "devDependencies": {
        "eslint": "8.57.1",
        "eslint-config-prettier": "10.1.8",
        "mjml": "5.4.0",
        "prettier": "^3.1.1",
        "serverless": "4.38.1"
    }
}
